# === Test Environment Configuration ===
# Available values:
#   https://staging.pear.us    (Development environment)
#   https://release.pear.us   (Test/Staging environment, default)
#   https://pear.us            (Production environment)
#
# BASE_URL also determines:
#   1. Which domain replaces the {BASE_URL} placeholder in test cases
#   2. The environment tag in cookie filenames (e.g. cookie_release.json / cookie_staging.json)
#   3. Which environment name replaces the {ENV} placeholder in YAML files
BASE_URL=https://release.pear.us
# BASE_URL=https://staging.pear.us
# BASE_URL=https://pear.us

# === Gemini AI Keys (used for AI Self-Healing) ===
# GEMINI_API_KEYS=key1,key2,key3
