# === 测试环境配置 ===
# 可选值:
#   https://staging.pear.us   (开发环境)
#   https://release.pear.us   (测试环境, 默认)
#   https://pear.us           (生产环境)
#
# BASE_URL 同时决定了:
#   1. 测试用例中 {BASE_URL} 占位符替换为哪个域名
#   2. cookie 文件名中的环境标识（如 cookie_release.json / cookie_staging.json）
#   3. YAML 中 {ENV} 占位符替换为对应环境名
BASE_URL=https://release.pear.us
# BASE_URL=https://release.pear.us
# BASE_URL=https://pear.us

# === Gemini AI Keys (用于 AI 自愈) ===
# GEMINI_API_KEYS=key1,key2,key3
